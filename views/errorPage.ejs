<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Page Not Found | Shivam Kumar</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        .error-page {
            min-height: 100vh;
            background: #0a0a0a;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .error-page::before {
            content: '';
            position: fixed;
            top: -180px;
            right: -100px;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(232, 69, 37, 0.13) 0%, transparent 70%);
            pointer-events: none;
        }

        .error-page::after {
            content: '';
            position: fixed;
            bottom: -150px;
            left: -80px;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(232, 69, 37, 0.08) 0%, transparent 70%);
            pointer-events: none;
        }

        .ep-logo img {
            height: 80px;
            position: fixed;
        }

        .ep-badge {
            background: rgba(232, 69, 37, 0.12);
            border: 1px solid rgba(232, 69, 37, 0.38);
            color: #e84525;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 3px;
            text-transform: uppercase;
            padding: 6px 18px;
            border-radius: 100px;
        }

        .ep-code {
            font-size: clamp(100px, 22vw, 165px);
            font-weight: 900;
            line-height: 1;
            color: transparent;
            -webkit-text-stroke: 2px rgba(232, 69, 37, 0.2);
            position: relative;
            user-select: none;
            letter-spacing: -4px;
        }

        .ep-code::after {
            content: attr(data-text);
            position: absolute;
            inset: 0;
            color: transparent;
            -webkit-text-stroke: 2px #e84525;
            clip-path: polygon(0 0, 100% 0, 100% 44%, 0 44%);
        }

        .ep-title {
            font-size: clamp(22px, 4vw, 34px);
            font-weight: 700;
            color: #ffffff;
            letter-spacing: -0.5px;
        }

        .ep-desc {
            font-size: 15px;
            color: rgba(255, 255, 255, 0.42);
            max-width: 380px;
            line-height: 1.75;
        }

        .ep-btn-primary {
            background: #e84525;
            color: #ffffff;
            font-size: 14px;
            font-weight: 500;
            padding: 12px 28px;
            border-radius: 8px;
            text-decoration: none;
            border: none;
            transition: background 0.2s ease, transform 0.15s ease;
            letter-spacing: 0.3px;
        }

        .ep-btn-primary:hover {
            background: #c93a1f;
            transform: translateY(-2px);
            color: #ffffff;
            text-decoration: none;
        }

        .ep-btn-secondary {
            background: transparent;
            color: rgba(255, 255, 255, 0.55);
            font-size: 14px;
            font-weight: 400;
            padding: 12px 24px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            text-decoration: none;
            transition: border-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
        }

        .ep-btn-secondary:hover {
            border-color: rgba(255, 255, 255, 0.3);
            color: #ffffff;
            transform: translateY(-2px);
            text-decoration: none;
        }

        .ep-divider {
            width: 48px;
            height: 1px;
            background: rgba(255, 255, 255, 0.07);
        }

        .ep-link {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.28);
            text-decoration: none;
            transition: color 0.2s ease;
        }

        .ep-link:hover {
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
        }

        .ep-footer {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.13);
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }
    </style>
</head>

<body>

    <div class="error-page w-100">
        <div class="container d-flex flex-column align-items-center text-center px-3"
            style="position:relative; z-index:1;">

            <!-- Logo -->
            <div class="align-self-start mb-5">
                <span class="ep-logo"><img src="/img/logo.png" src="logoImage"></span>
            </div>

            <!-- Badge -->
            <span class="ep-badge mb-2">
                <%=error%>
            </span>

            <!-- 404 -->
            <div class="ep-code mb-2" data-text="<%=code%>">
                <%=code%>
            </div>

            <!-- Title -->
            <h1 class="ep-title mb-3">Page Not Found</h1>

            <!-- Description -->
            <p class="ep-desc mb-5">
                Looks like this page took a wrong turn. The page you're looking for doesn't exist or may have been
                moved.
            </p>

            <!-- Buttons -->
            <div class="d-flex flex-wrap gap-3 justify-content-center mb-5">
                <a href="/" class="ep-btn-primary d-flex align-items-center gap-2">
                    <i class="fa-solid fa-house"></i>
                    Back to Home
                </a>
                <a href="/#hireMe" class="ep-btn-secondary d-flex align-items-center gap-2">
                    <i class="fa-solid fa-envelope"></i>
                    Contact Me
                </a>
            </div>

            <!-- Divider -->
            <div class="ep-divider mb-4"></div>

            <!-- Nav Links -->
            <div class="d-flex flex-wrap gap-4 justify-content-center mb-5">
                <a href="/#about" class="ep-link">About</a>
                <a href="/#services" class="ep-link">Services</a>
                <a href="/#projects" class="ep-link">Projects</a>
                <a href="/#education" class="ep-link">Education</a>
                <a href="/#hireMe" class="ep-link">Hire Me</a>
            </div>

            <!-- Footer -->
            <p class="ep-footer">© 2026 Shivam Kumar Rajput</p>

        </div>
    </div>

</body>

</html>